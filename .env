# ================================================================
# .env — shared variables loaded by Docker Compose on both machines
#
# MASTER MACHINE: set MASTER_IP to this machine's LAN IP
# WORKER MACHINE: set MASTER_IP to master's LAN IP, WORKER_IP to this machine's LAN IP
#
# LAN example: MASTER_IP=192.168.x.x WORKER_IP=192.168.x.x
# ================================================================
# === NETWORK ===
# Master machine LAN IP — used everywhere (Kafka external, Spark Master URL, MinIO external)
MASTER_IP=192.168.110.188

# Primary worker LAN IP — kept for backward-compatible single-worker settings.
WORKER_IP=192.168.110.70

# Stable hostname advertised by the Spark worker on the current worker machine.
# On worker A: spark-worker-A. On worker B: spark-worker-B.
SPARK_WORKER_HOST=spark-worker-A

# Worker inventory used by the master container and Prometheus.
# Current master: 192.168.110.188
# Worker A:      192.168.110.70
# Worker B:      192.168.110.229
SPARK_WORKER_A_HOST=spark-worker-A
SPARK_WORKER_A_IP=192.168.110.70
SPARK_WORKER_B_HOST=spark-worker-B
SPARK_WORKER_B_IP=192.168.110.229
SPARK_WORKER_C_HOST=spark-worker-C
SPARK_WORKER_C_IP=192.168.110.42


# On a worker machine, set this to the *other* worker so executor shuffle
# traffic can resolve peer hostnames without mapping the worker's own hostname.
# Worker A: peer=B. Worker B: peer=A.
SPARK_PEER_WORKER_HOST=spark-worker-B
SPARK_PEER_WORKER_IP=192.168.110.229

# === MINIO ===
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
# Internal (within master Docker network): containers use this
MINIO_ENDPOINT=http://minio:9000
# External (for Airflow DAGs, outside Docker, or cross-machine references)
MINIO_ENDPOINT_EXTERNAL=http://192.168.110.188:9000

# === KAFKA ===
# Internal: producers/consumers inside master Docker network
KAFKA_BOOTSTRAP_INTERNAL=kafka:9092
# External: worker machines connect to this via LAN
KAFKA_BOOTSTRAP_EXTERNAL=192.168.110.188:29092

# === SPARK ===
# Workers connect to master at LAN IP:7077
SPARK_MASTER_URL=spark://192.168.110.188:7077
# Shared checkpoint root for all streaming jobs.
STREAMING_CHECKPOINT_BASE=s3a://checkpoints
# Job 2/3/4 are stateful streams. Keep their checkpoints on MinIO so the
# executors can run on Spark workers instead of loading the spark-master container.
STATEFUL_CHECKPOINT_BASE=s3a://checkpoints
STATEFUL_STREAM_MASTER=spark://spark-master:7077
# Slower demo cadence: reduce Spark scheduling/write pressure.
SPARK_TRIGGER_INTERVAL_S=15
SOURCE_WAIT_POLL_S=15
LAUNCHER_POLL_INTERVAL_S=15
KAFKA_MAX_OFFSETS_PER_TRIGGER=50000
# Gold job tuning. Faster micro-batches, but still bounded to keep state stable.
GOLD_TRIGGER_INTERVAL_S=15
JOB1_EXECUTOR_CORES=2
JOB1_TOTAL_CORES=2
JOB1_EXECUTOR_MEMORY=4g
JOB1_DRIVER_MEMORY=1g
JOB1_SHUFFLE_PARTITIONS=6
JOB2_EXECUTOR_CORES=2
JOB2_TOTAL_CORES=2
JOB2_EXECUTOR_MEMORY=3g
JOB2_DRIVER_MEMORY=1g
JOB2_SHUFFLE_PARTITIONS=6
JOB3_EXECUTOR_CORES=2
JOB3_TOTAL_CORES=2
JOB3_EXECUTOR_MEMORY=3g
JOB3_DRIVER_MEMORY=1g
JOB3_SHUFFLE_PARTITIONS=6
JOB4_EXECUTOR_CORES=2
JOB4_TOTAL_CORES=2
JOB4_EXECUTOR_MEMORY=3g
JOB4_DRIVER_MEMORY=1g
JOB4_SHUFFLE_PARTITIONS=6
GOLD_MAX_FILES_PER_TRIGGER=12
GOLD_WINDOW_DURATION="30 minutes"
GOLD_SLIDE_DURATION="15 minutes"
GOLD_WINDOW_LOOKBACK_MINUTES=60
JOB5_EXECUTOR_CORES=2
JOB5_TOTAL_CORES=4
JOB5_EXECUTOR_MEMORY=4g
JOB5_DRIVER_MEMORY=2g
JOB5_SHUFFLE_PARTITIONS=12
# Worker resources — tune per machine (12GB RAM: dùng 10g để lại 2g cho OS)
SPARK_WORKER_MEMORY=10g
SPARK_WORKER_CORES=6

# === POSTGRES ===
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin123
POSTGRES_DB=bigdata

# === AIRFLOW ===
AIRFLOW_FERNET_KEY=ZmDfcTF7_60GrrY167zsiPd67pEvs0aGOv2oasOM1Pg=
AIRFLOW_SECRET_KEY=bigdata-secret-key-2025

# === MLFLOW ===
# External URI for local scripts and browser access.
MLFLOW_TRACKING_URI=http://192.168.110.188:5000
# Internal URI for containers on the master Docker network.
MLFLOW_TRACKING_URI_INTERNAL=http://mlflow:5000

# === PREDICT SERVICE ===
# 1800s = 30 minutes wall clock. Prediction becomes periodic instead of near-realtime.
PREDICT_POLL_INTERVAL_S=1800
PREDICT_EMPTY_RETRY_INTERVAL_S=60
MODEL_RELOAD_INTERVAL_S=1800

# === PRODUCER ===
SPEED_FACTOR=0.5
PRODUCER_BATCH_SIZE=50000
PRODUCER_FLUSH_EVERY=100000
PRODUCER_LOG_EVERY=50000
KAFKA_ACKS=1
# Optional demo window. Leave empty/unset to stream all available files.
# PRODUCER_START_TIME=2026-02-01T00:00:00
# PRODUCER_END_TIME=2026-02-02T00:00:00
DATASET_PATH=./datasets

# === WEATHER ===
# Local parquet: datasets/parquet_by_day/ — mỗi file là 1 ngày (YYYY-MM-DD.parquet)
# predict-service mount tại: /datasets/parquet_by_day
# airflow        mount tại: /opt/airflow/datasets/parquet_by_day
WEATHER_PARQUET_BY_DAY=./datasets/parquet_by_day
WEATHER_PARQUET_LOCAL=./datasets/parquet_by_day
WEATHER_PARQUET_PATH=s3://weather/parquet
WEATHER_CSV_PATH=/datasets/weather/2526.csv
