# ================================================================
# .env — Topology: Master=SparkMaster+Tools | Worker=SparkWorker+Kafka+MinIO
# SỬA 2 dòng này trước khi chạy:
#   MASTER_IP = IP máy Master (có Spark Master, Airflow, Grafana...)
#   WORKER_IP = IP máy Worker (có Spark Worker, Kafka, MinIO...)
# ================================================================

# ── NETWORK ─────────────────────────────────────────────────────
MASTER_IP=192.168.110.188
WORKER_IP=192.168.110.70

SPARK_WORKER_HOST=spark-worker-A
SPARK_WORKER_A_HOST=spark-worker-A
SPARK_WORKER_A_IP=192.168.110.70
# B và C không tồn tại → trỏ 127.0.0.1 để Prometheus không timeout
SPARK_WORKER_B_HOST=spark-worker-B
SPARK_WORKER_B_IP=127.0.0.1
SPARK_WORKER_C_HOST=spark-worker-C
SPARK_WORKER_C_IP=127.0.0.1
SPARK_PEER_WORKER_HOST=spark-worker-B
SPARK_PEER_WORKER_IP=127.0.0.1

# ── MINIO (chạy trên Worker machine) ────────────────────────────
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
# Internal: executor dùng hostname Docker "minio:9000" (local trên Worker)
MINIO_ENDPOINT=http://minio:9000
# External: Master machine (predict-service, Airflow) dùng IP
MINIO_ENDPOINT_EXTERNAL=http://192.168.110.70:9000

# ── KAFKA (chạy trên Worker machine) ────────────────────────────
# Internal: executor dùng hostname Docker "kafka:9092" (local trên Worker)
KAFKA_BOOTSTRAP_INTERNAL=kafka:9092
# External: Producers trên Master gửi data vào Kafka qua LAN
KAFKA_BOOTSTRAP_EXTERNAL=192.168.110.70:29092

# ── SPARK ────────────────────────────────────────────────────────
# Spark Master chạy trên Master machine
SPARK_MASTER_URL=spark://192.168.110.188:7077
# Driver chạy trên Master machine (deploy-mode client, spark-submit trên Master)
# Driver kết nối Executor (Worker) qua MASTER_IP — Executor reply về MASTER_IP
STREAMING_CHECKPOINT_BASE=s3a://checkpoints
STATEFUL_CHECKPOINT_BASE=s3a://checkpoints
STATEFUL_STREAM_MASTER=spark://192.168.110.188:7077

# ── TRIGGER INTERVAL ─────────────────────────────────────────────
# T=30s: overhead cố định ~800ms/trigger, chiếm 2.7% thời gian → OK
# Pipeline latency: 4×30s = 2 phút (request → silver/complete)
# Không lag vì C=87 events/s × 30s = 2610 msg → proc ~1s << 30s
SPARK_TRIGGER_INTERVAL_S=30
SOURCE_WAIT_POLL_S=30
LAUNCHER_POLL_INTERVAL_S=30

# Job5 riêng: foreachBatch serialized → 1 executor chỉ chạy 1 batch/lần
# 60s: MERGE Gold 2× ít hơn T=30s, scan silver/response 2× ít hơn
GOLD_TRIGGER_INTERVAL_S=60

# ── KAFKA THROTTLE ───────────────────────────────────────────────
# SF=5, C=87/s, T=30s → 2610 msg/trigger thực tế
# Đặt 5000 = buffer 2× → không bao giờ bị cap, không Kafka lag
KAFKA_MAX_OFFSETS_PER_TRIGGER=5000

# ── GOLD WINDOW ──────────────────────────────────────────────────
# Window 30 phút (tên "requests_60m" là alias trong code, không phải bug)
# Slide 15 phút: mỗi giờ có 4 windows → Gold 263×4=1052 rows/giờ
# Trước là slide 5 phút → 12 windows/giờ → Gold 263×12=3156 rows/giờ → quá nhiều
# Slide 15 phút đủ granularity cho predict, ít rows hơn 3× → MERGE nhanh hơn
GOLD_WINDOW_DURATION=60 minutes
GOLD_SLIDE_DURATION=15 minutes
# Lookback 30 phút: khi foreachBatch đọc silver/response, chỉ scan 30 phút
# = 1× WINDOW_DURATION → đủ để cover tất cả trips trong window hiện tại
GOLD_WINDOW_LOOKBACK_MINUTES=60
# 10 files/trigger: mỗi file Job4 ghi ≈ 1-3 MB Parquet → batch ~10-30 MB
# Vừa đủ cho executor 3584m, không quá lớn gây OOM
GOLD_MAX_FILES_PER_TRIGGER=10

# ── SPEED FACTOR ─────────────────────────────────────────────────
# SF=5: 1 giờ event time = 12 phút real time
# Demo 30 phút real time = 2.5 giờ event data
# → Thấy rõ pattern cao điểm / thấp điểm NYC trong demo
# SF an toàn tối đa = 10 với config Job4 hiện tại (state pool 985MB)
# SF=5: Job4 state = 63MB << 985MB → dư sức
SPEED_FACTOR=3

# ── WATERMARK / JOIN RANGE ───────────────────────────────────────
# Các giá trị này được đọc trực tiếp trong code Python.
# Để ở đây để tiện thay đổi không cần sửa code.
# Job3 (request→response): pickup phải đến trong 1h sau request
# Thực tế NYC taxi: 95% pickup < 15 phút, 99% < 1h → 1h là đủ
JOB3_RANGE_HOURS=0.4
# Job4 (complete→silver): dropoff phải trong 1h sau pickup
# NYC taxi: 95% chuyến < 45 phút, 99% < 1h → 1h hợp lý
JOB4_RANGE_HOURS=1
# Watermark response stream trong Job4: 10 phút
# Trước là 30 phút → state giữ response 30 phút dư → giảm xuống 10 phút
# State Job4 = C/3 × RANGE_HOURS×3600 × 600B = 87/3 × 3600 × 600 / 1e6 = 63MB
JOB4_RESPONSE_WATERMARK_MINUTES=30

# ── JOB RESOURCES ───────────────────────────────────────────────
# Worker: 16GB RAM, 12 core → cấp SPARK_WORKER_MEMORY=12g, CORES=10
#
# Tổng executor RAM (slot = executor-memory + memoryOverhead):
#   Job1: (1280 + 256) / 1024 = 1.500g  → 1 executor × 2 cores
#   Job2:  (640 + 256) / 1024 = 0.875g  → 1 executor × 1 core
#   Job3: (1024 + 256) / 1024 = 1.250g  → 1 executor × 1 core
#   Job4: (2816 + 256) / 1024 = 3.000g  → 1 executor × 2 cores
#   Job5: (3584 + 384) / 1024 = 3.875g  → 1 executor × 2 cores
#   TOTAL = 10.500g ≤ 12g ✅  buffer 1.5g cho OS/Docker overhead
#   Cores: 2+1+1+2+2 = 8/10 ✅  dư 2 cores cho worker daemon

# Job1: kafka→bronze
# 1280m: storage pool = 1280×0.35 = 448MB
# SF=5: batch_df.cache ≈ 2610×800B/1e6 = 2MB << 448MB → không spill
# 2 cores: 1 xử lý Kafka deserialize, 1 xử lý S3A write song song
JOB1_EXECUTOR_CORES=2
JOB1_TOTAL_CORES=2
JOB1_EXECUTOR_MEMORY=1280m
JOB1_MEMORY_OVERHEAD=256m
JOB1_DRIVER_MEMORY=256m
JOB1_SHUFFLE_PARTITIONS=4

# Job2: request→silver (stateless — chỉ select + filter + cast)
# 640m: storage pool = 640×0.35 = 224MB >> workload 5MB → dư rất nhiều
# 1 core đủ: không có join, không có state, throughput thấp
JOB2_EXECUTOR_CORES=1
JOB2_TOTAL_CORES=1
JOB2_EXECUTOR_MEMORY=640m
JOB2_MEMORY_OVERHEAD=256m
JOB2_DRIVER_MEMORY=256m
JOB2_SHUFFLE_PARTITIONS=4

# Job3: request→response (stream-stream join, state nhỏ)
# State: request watermark 10min → (87/3)×600×400B/1e6 = 7MB
# 1024m: storage pool = 358MB >> 7MB → buffer 50× → thoải mái
# RANGE 1h (sửa từ 2h): state giảm 2×, join vẫn đúng vì 99% pickup < 1h
JOB3_EXECUTOR_CORES=1
JOB3_TOTAL_CORES=1
JOB3_EXECUTOR_MEMORY=1024m
JOB3_MEMORY_OVERHEAD=256m
JOB3_DRIVER_MEMORY=256m
JOB3_SHUFFLE_PARTITIONS=4

# Job4: complete→silver (stream-stream join, state lớn nhất)
# RANGE đổi từ 6h → 1h: state giảm 6× (từ 376MB → 63MB với SF=5)
# RESPONSE_WATERMARK đổi từ 30min → 10min: evict state sớm hơn
# 2816m: storage pool = 2816×0.35 = 985MB >> state 63MB → buffer 15×
# 2 cores: 1 xử lý dropoff state, 1 xử lý S3A checkpoint write
JOB4_EXECUTOR_CORES=2
JOB4_TOTAL_CORES=2
JOB4_EXECUTOR_MEMORY=2816m
JOB4_MEMORY_OVERHEAD=256m
JOB4_DRIVER_MEMORY=256m
JOB4_SHUFFLE_PARTITIONS=4

# Job5: silver→gold (foreachBatch + batch read silver/response)
# total_cores=2 → executor_cores=2 → SỐ EXECUTOR = 2/2 = 1 executor
# foreachBatch chạy tuần tự (serialized): batch N xong rồi mới chạy batch N+1
# → 2 executor không chạy song song → lãng phí. 1 executor là đủ.
# storageFraction=0.5 (set trong submit-jobs.sh): tăng storage pool
# 3584m với fraction 0.5: storage pool = 3584×0.7×0.5 = 1254MB
# 3 persists (batch_df + demand_60m + gold) ≈ 110MB << 1254MB ✅
# batch read silver/response sau 2h ≈ 22MB << execution pool 1254MB ✅
JOB5_EXECUTOR_CORES=2
JOB5_TOTAL_CORES=2
JOB5_EXECUTOR_MEMORY=3584m
JOB5_MEMORY_OVERHEAD=384m
JOB5_DRIVER_MEMORY=512m
JOB5_SHUFFLE_PARTITIONS=4
JOB5_STORAGE_FRACTION=0.5

# ── WORKER ──────────────────────────────────────────────────────
# 12g: dư 1.5g buffer so với 10.5g executor request
# 10 cores: dư 2 cores cho worker daemon và OS
SPARK_WORKER_MEMORY=12g
SPARK_WORKER_CORES=10

# ── POSTGRES ────────────────────────────────────────────────────
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin123
POSTGRES_DB=bigdata

# ── AIRFLOW ─────────────────────────────────────────────────────
AIRFLOW_FERNET_KEY=ZmDfcTF7_60GrrY167zsiPd67pEvs0aGOv2oasOM1Pg=
AIRFLOW_SECRET_KEY=bigdata-secret-key-2025

# ── MLFLOW ──────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://192.168.110.188:5000
MLFLOW_TRACKING_URI_INTERNAL=http://mlflow:5000

# ── PREDICT SERVICE ─────────────────────────────────────────────
# 1800s = 30 phút: bottleneck thực sự của latency end-to-end
# Pipeline Spark → Gold latency ≈ 2 phút → predict poll mới là nút thắt
POLL_INTERVAL_S=300
PREDICT_EMPTY_RETRY_INTERVAL_S=60
MODEL_RELOAD_INTERVAL_S=1800

# ── DATASET ─────────────────────────────────────────────────────
DATASET_PATH=./datasets
WEATHER_PARQUET_BY_DAY=./datasets/parquet_by_day
WEATHER_PARQUET_LOCAL=./datasets/parquet_by_day
WEATHER_PARQUET_PATH=s3://weather/parquet
WEATHER_CSV_PATH=/datasets/weather/2526.csv
KAFKA_ACKS=1