# ================================================================
# .env — shared variables loaded by Docker Compose on both machines
#
# MASTER MACHINE: set MASTER_IP to this machine's VPN IP
# WORKER MACHINE: set MASTER_IP to master's VPN IP, WORKER_IP to this machine's VPN IP
#
# Radmin VPN example:  MASTER_IP=26.x.x.x  WORKER_IP=26.x.x.x
# Tailscale example:   MASTER_IP=100.x.x.x WORKER_IP=100.x.x.x
# Local hotspot:       MASTER_IP=192.168.x.x WORKER_IP=192.168.x.x
# ================================================================

# === NETWORK ===
# Master machine VPN IP — used everywhere (Kafka external, Spark Master URL, MinIO external)
MASTER_IP=26.251.182.54

# Worker machine VPN IP — used in docker-compose.worker.yml for Spark registration.
# On the worker machine, change this to the actual VPN IP of that laptop.
# This is what the Spark Master will use to send tasks back to the worker.
WORKER_IP=26.237.119.249

# === MINIO ===
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
# Internal (within master Docker network): containers use this
MINIO_ENDPOINT=http://minio:9000
# External (for Airflow DAGs, outside Docker, or cross-machine references)
MINIO_ENDPOINT_EXTERNAL=http://26.251.182.54:9000

# === KAFKA ===
# Internal: producers/consumers inside master Docker network
KAFKA_BOOTSTRAP_INTERNAL=kafka:9092
# External: worker machines connect to this via VPN
KAFKA_BOOTSTRAP_EXTERNAL=192.168.10.1:29092

# === SPARK ===
# Workers connect to master at VPN IP:7077
SPARK_MASTER_URL=spark://26.237.119.249:7077
# Worker resources — tune per machine (12GB RAM: dùng 10g để lại 2g cho OS)
SPARK_WORKER_MEMORY=14g
SPARK_WORKER_CORES=12

# === POSTGRES ===
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin123
POSTGRES_DB=bigdata

# === AIRFLOW ===
AIRFLOW_FERNET_KEY=ZmDfcTF7_60GrrY167zsiPd67pEvs0aGOv2oasOM1Pg=
AIRFLOW_SECRET_KEY=bigdata-secret-key-2025

# === MLFLOW ===
MLFLOW_TRACKING_URI=http://26.237.119.249:5000

# === PRODUCER ===
SPEED_FACTOR=60
DATASET_PATH=./datasets

# === WORKER ID (set differently on each worker machine: A, B, C...) ===
WORKER_ID=A

# === WEATHER ===
# Local parquet: datasets/parquet_by_day/ — mỗi file là 1 ngày (YYYY-MM-DD.parquet)
# predict-service mount tại: /datasets/parquet_by_day
# airflow        mount tại: /opt/airflow/datasets/parquet_by_day
WEATHER_PARQUET_BY_DAY=./datasets/parquet_by_day
WEATHER_PARQUET_LOCAL=./datasets/parquet_by_day
WEATHER_PARQUET_PATH=s3://weather/parquet
WEATHER_CSV_PATH=/datasets/weather/2526.csv
