# ================================================================
# .env — Tập trung toàn bộ config, không hardcode trong code
# ================================================================

# === NETWORK ===
MASTER_IP=192.168.10.1          # IP tĩnh máy Master trên hotspot

# === MINIO ===
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_ENDPOINT=http://minio:9000
MINIO_ENDPOINT_EXTERNAL=http://192.168.10.1:9000

# === KAFKA ===
KAFKA_BOOTSTRAP_INTERNAL=kafka:9092
KAFKA_BOOTSTRAP_EXTERNAL=192.168.10.1:29092

# === SPARK ===
SPARK_MASTER_URL=spark://192.168.10.1:7077
SPARK_WORKER_MEMORY=13G
SPARK_WORKER_CORES=10

# === POSTGRES (dùng chung Airflow + MLflow + Grafana) ===
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin123
POSTGRES_DB=bigdata

# === AIRFLOW ===
AIRFLOW_FERNET_KEY=ZmDfcTF7_60GrrY167zsiPd67pEvs0aGOv2oasOM1Pg=
AIRFLOW_SECRET_KEY=bigdata-secret-key-2025

# === MLFLOW ===
MLFLOW_TRACKING_URI=http://192.168.10.1:5000

# === PRODUCER ===
SPEED_FACTOR=60
DATASET_PATH=/opt/datasets

# === WORKER ID (đặt khác nhau trên mỗi máy worker) ===
# Machine 2: WORKER_ID=A
# Machine 3: WORKER_ID=B
WORKER_ID=A

# ── Weather CSV ───────────────────────────────────────────────────────────────
# ⚠️ Phải đặt file 2526.csv vào đúng path này trong DATASET_PATH
# Cấu trúc: $DATASET_PATH/weather/2526.csv
WEATHER_CSV_PATH=/datasets/weather/2526.csv