{
  "title": "NYC Taxi — Infrastructure Monitoring",
  "uid": "nyc-infra-monitoring",
  "schemaVersion": 38,
  "version": 2,
  "refresh": "15s",
  "time": { "from": "now-6h", "to": "now" },
  "tags": ["infrastructure", "kafka", "spark", "airflow"],
  "panels": [
    {
      "id": 1,
      "title": "Kafka UP",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        { "expr": "up{job=\"kafka\"}", "legendFormat": "Kafka" }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "1": { "text": "UP", "color": "green" } } },
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" } } }
          ],
          "thresholds": { "steps": [ { "color": "red", "value": 0 }, { "color": "green", "value": 1 } ] }
        }
      }
    },
    {
      "id": 2,
      "title": "Spark Master UP",
      "type": "stat",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        { "expr": "up{job=\"spark-master\"}", "legendFormat": "Spark Master" }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "1": { "text": "UP", "color": "green" } } },
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" } } }
          ],
          "thresholds": { "steps": [ { "color": "red", "value": 0 }, { "color": "green", "value": 1 } ] }
        }
      }
    },
    {
      "id": 3,
      "title": "MinIO UP",
      "type": "stat",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        { "expr": "up{job=\"minio\"}", "legendFormat": "MinIO" }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "1": { "text": "UP", "color": "green" } } },
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" } } }
          ],
          "thresholds": { "steps": [ { "color": "red", "value": 0 }, { "color": "green", "value": 1 } ] }
        }
      }
    },
    {
      "id": 4,
      "title": "Airflow UP",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        { "expr": "up{job=\"airflow\"}", "legendFormat": "Airflow" }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "1": { "text": "UP", "color": "green" } } },
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" } } }
          ],
          "thresholds": { "steps": [ { "color": "red", "value": 0 }, { "color": "green", "value": 1 } ] }
        }
      }
    },
    {
      "id": 5,
      "title": "Predict Service UP",
      "type": "stat",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        { "expr": "up{job=\"predict-service\"}", "legendFormat": "Predict Service" }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "1": { "text": "UP", "color": "green" } } },
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" } } }
          ],
          "thresholds": { "steps": [ { "color": "red", "value": 0 }, { "color": "green", "value": 1 } ] }
        }
      }
    },
    {
      "id": 6,
      "title": "Spark Workers Alive",
      "type": "stat",
      "gridPos": { "x": 20, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        { "expr": "metrics_master_aliveWorkers_Value", "legendFormat": "Alive workers" }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "steps": [ { "color": "red", "value": 0 }, { "color": "yellow", "value": 1 }, { "color": "green", "value": 2 } ] }
        }
      }
    },
    {
      "id": 7,
      "title": "Kafka Topic Offsets",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        { "expr": "kafka_log_log_end_offset{topic=\"nyc_taxi_events\"}", "legendFormat": "Partition {{partition}}" }
      ],
      "fieldConfig": { "defaults": { "custom": { "fillOpacity": 20 } } }
    },
    {
      "id": 8,
      "title": "Kafka Messages In / sec",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        { "expr": "kafka_server_brokertopicmetrics_messagesin_rate1m{topic=\"nyc_taxi_events\"}", "legendFormat": "Messages/sec" }
      ]
    },
    {
      "id": 9,
      "title": "Predict Service Last Prediction Age (min)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 12, "w": 8, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        { "expr": "(time() - predict_service_last_prediction_timestamp) / 60", "legendFormat": "Minutes" }
      ],
      "fieldConfig": { "defaults": { "unit": "m" } }
    },
    {
      "id": 10,
      "title": "Predict Service Model Loaded",
      "type": "stat",
      "gridPos": { "x": 8, "y": 12, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        { "expr": "predict_service_model_loaded", "legendFormat": "Loaded" }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "1": { "text": "LOADED", "color": "green" } } },
            { "type": "value", "options": { "0": { "text": "NOT LOADED", "color": "red" } } }
          ]
        }
      }
    },
    {
      "id": 11,
      "title": "Predict Service Zones Last Slot",
      "type": "stat",
      "gridPos": { "x": 12, "y": 12, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        { "expr": "predict_service_zones_predicted_last_slot", "legendFormat": "Zones" }
      ]
    },
    {
      "id": 12,
      "title": "MinIO Storage Used (GB)",
      "type": "stat",
      "gridPos": { "x": 16, "y": 12, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        { "expr": "minio_cluster_usage_total_bytes / 1024 / 1024 / 1024", "legendFormat": "GB" }
      ],
      "fieldConfig": { "defaults": { "unit": "gbytes" } }
    },
    {
      "id": 13,
      "title": "Airflow Task Success",
      "type": "timeseries",
      "gridPos": { "x": 20, "y": 12, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        { "expr": "increase(airflow_task_success_total[24h])", "legendFormat": "Success" }
      ]
    },
    {
      "id": 14,
      "title": "Host CPU Usage (%)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        { "expr": "100 - (avg by(instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[1m])) * 100)", "legendFormat": "CPU {{instance}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 } }
    },
    {
      "id": 15,
      "title": "Host RAM Usage (%)",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 16, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        { "expr": "100 - ((node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes) * 100)", "legendFormat": "RAM {{instance}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 } }
    },
    {
      "id": 16,
      "title": "Container CPU Usage",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 16, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        { "expr": "sum by(instance) (rate(container_cpu_usage_seconds_total{id=\"/\"}[1m])) * 100", "legendFormat": "{{instance}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "percent" } }
    }
  ]
}