          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT\n    window_end AS \"time\",\n    SUM(CASE WHEN predicted_class = 0 THEN 1 ELSE 0 END) AS \"0 – None\",\n    SUM(CASE WHEN predicted_class = 1 THEN 1 ELSE 0 END) AS \"1 – Very Low\",\n    SUM(CASE WHEN predicted_class = 2 THEN 1 ELSE 0 END) AS \"2 – Low\",\n    SUM(CASE WHEN predicted_class = 3 THEN 1 ELSE 0 END) AS \"3 – Medium\",\n    SUM(CASE WHEN predicted_class = 4 THEN 1 ELSE 0 END) AS \"4 – High\",\n    SUM(CASE WHEN predicted_class = 5 THEN 1 ELSE 0 END) AS \"5 – Critical\"\nFROM predictions_monitoring\nWHERE $__timeFilter(window_end)\nGROUP BY window_end\nORDER BY window_end",
          "refId": "A"
        }
      ],
