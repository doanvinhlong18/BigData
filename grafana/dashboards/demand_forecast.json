{
  "title": "NYC Taxi Demand Forecast",
  "uid": "nyc-demand-v2",
  "version": 2,
  "refresh": "1m",
  "time": {"from": "now-24h", "to": "now"},
  "panels": [
    {"id":1,"title":"Total Requests (24h)","type":"stat","gridPos":{"x":0,"y":0,"w":4,"h":4},
     "options":{"reduceOptions":{"calcs":["lastNotNull"]},"colorMode":"background","graphMode":"none"},
     "targets":[{"datasource":"BigData-API","type":"json","url":"/stats/overall","root_selector":"",
      "columns":[{"selector":"total_requests_24h","text":"Requests","type":"number"}]}]},

    {"id":2,"title":"Model Accuracy (24h avg)","type":"stat","gridPos":{"x":4,"y":0,"w":4,"h":4},
     "fieldConfig":{"defaults":{"unit":"percentunit","min":0,"max":1,
       "thresholds":{"steps":[{"value":0,"color":"red"},{"value":0.55,"color":"yellow"},{"value":0.70,"color":"green"}]}}},
     "options":{"reduceOptions":{"calcs":["lastNotNull"]},"colorMode":"background"},
     "targets":[{"datasource":"BigData-API","type":"json","url":"/stats/overall","root_selector":"",
      "columns":[{"selector":"avg_accuracy_24h","text":"Accuracy","type":"number"}]}]},

    {"id":3,"title":"Weather Fallback Rate","type":"stat","gridPos":{"x":8,"y":0,"w":4,"h":4},
     "fieldConfig":{"defaults":{"unit":"percentunit"}},
     "options":{"reduceOptions":{"calcs":["lastNotNull"]},"colorMode":"background"},
     "targets":[{"datasource":"BigData-API","type":"json","url":"/stats/overall","root_selector":"",
      "columns":[{"selector":"fallback_rate","text":"Fallback","type":"number"}]}]},

    {"id":4,"title":"Windows Processed (24h)","type":"stat","gridPos":{"x":12,"y":0,"w":4,"h":4},
     "options":{"reduceOptions":{"calcs":["lastNotNull"]},"colorMode":"none"},
     "targets":[{"datasource":"BigData-API","type":"json","url":"/stats/overall","root_selector":"",
      "columns":[{"selector":"windows_processed","text":"Windows","type":"number"}]}]},

    {"id":5,"title":"Total Requests Over Time","type":"timeseries","gridPos":{"x":0,"y":4,"w":16,"h":8},
     "targets":[{"datasource":"BigData-API","type":"json","url":"/demand/history?hours=24",
      "root_selector":"data",
      "columns":[{"selector":"window_end","text":"Time","type":"timestamp"},
                  {"selector":"total_requests_60m","text":"Requests 60m","type":"number"},
                  {"selector":"total_requests_15m","text":"Requests 15m","type":"number"}]}]},

    {"id":6,"title":"Pickup Delay Mean (avg all zones)","type":"timeseries","gridPos":{"x":0,"y":12,"w":16,"h":8},
     "fieldConfig":{"defaults":{"unit":"s"}},
     "targets":[{"datasource":"BigData-API","type":"json","url":"/demand/history?hours=24",
      "root_selector":"data",
      "columns":[{"selector":"window_end","text":"Time","type":"timestamp"},
                  {"selector":"avg_pickup_delay","text":"Pickup Delay (s)","type":"number"}]}]},

    {"id":7,"title":"Model Accuracy Trend","type":"timeseries","gridPos":{"x":0,"y":20,"w":12,"h":8},
     "fieldConfig":{"defaults":{"unit":"percentunit","min":0,"max":1}},
     "targets":[{"datasource":"BigData-API","type":"json","url":"/predictions/history?hours=24",
      "root_selector":"data",
      "columns":[{"selector":"eval_hour","text":"Hour","type":"timestamp"},
                  {"selector":"overall_accuracy","text":"Overall","type":"number"},
                  {"selector":"model_a_accuracy","text":"Model A","type":"number"},
                  {"selector":"model_b_accuracy","text":"Model B","type":"number"},
                  {"selector":"shadow_accuracy","text":"Shadow","type":"number"}]}]},

    {"id":8,"title":"Model A vs B (zone count)","type":"piechart","gridPos":{"x":12,"y":20,"w":8,"h":8},
     "targets":[{"datasource":"BigData-API","type":"json","url":"/predictions/model_split",
      "root_selector":"data",
      "columns":[{"selector":"model_label","text":"Model","type":"string"},
                  {"selector":"count","text":"Count","type":"number"}]}]},

    {"id":9,"title":"Demand per Zone — Latest Window","type":"table","gridPos":{"x":0,"y":28,"w":12,"h":10},
     "options":{"sortBy":[{"displayName":"Imbalance","desc":true}]},
     "targets":[{"datasource":"BigData-API","type":"json","url":"/demand/latest",
      "root_selector":"data",
      "columns":[{"selector":"zone_id","text":"Zone","type":"number"},
                  {"selector":"requests_60m","text":"Requests 60m","type":"number"},
                  {"selector":"pickup_delay_mean","text":"Pickup Delay(s)","type":"number"},
                  {"selector":"imbalance","text":"Imbalance","type":"number"},
                  {"selector":"avg_fare","text":"Avg Fare","type":"number"},
                  {"selector":"neighbor_requests_60m","text":"Nbr Requests","type":"number"}]}]},

    {"id":10,"title":"Predictions — Latest Window","type":"table","gridPos":{"x":12,"y":28,"w":12,"h":10},
     "options":{"sortBy":[{"displayName":"Confidence","desc":true}]},
     "targets":[{"datasource":"BigData-API","type":"json","url":"/predictions/latest",
      "root_selector":"data",
      "columns":[{"selector":"zone_id","text":"Zone","type":"number"},
                  {"selector":"predicted_label","text":"Demand Level","type":"string"},
                  {"selector":"pred_confidence","text":"Confidence","type":"number"},
                  {"selector":"actual_label","text":"Actual (if known)","type":"string"},
                  {"selector":"is_correct","text":"Correct","type":"boolean"},
                  {"selector":"used_model","text":"Model","type":"string"}]}]},

    {"id":11,"title":"Worst Predicted Zones (24h)","type":"table","gridPos":{"x":0,"y":38,"w":12,"h":8},
     "options":{"sortBy":[{"displayName":"Accuracy","desc":false}]},
     "targets":[{"datasource":"BigData-API","type":"json","url":"/predictions/per_zone?hours=24",
      "root_selector":"data",
      "columns":[{"selector":"zone_id","text":"Zone","type":"number"},
                  {"selector":"accuracy","text":"Accuracy","type":"number"},
                  {"selector":"n_evaluated","text":"N Evaluated","type":"number"},
                  {"selector":"avg_confidence","text":"Avg Confidence","type":"number"},
                  {"selector":"fallback_rate","text":"Fallback Rate","type":"number"}]}]},

    {"id":12,"title":"Shadow vs Production Accuracy","type":"timeseries","gridPos":{"x":12,"y":38,"w":12,"h":8},
     "fieldConfig":{"defaults":{"unit":"percentunit","min":0,"max":1}},
     "targets":[{"datasource":"BigData-API","type":"json","url":"/predictions/shadow_comparison?hours=72",
      "root_selector":"data",
      "columns":[{"selector":"eval_hour","text":"Hour","type":"timestamp"},
                  {"selector":"production_accuracy","text":"Production","type":"number"},
                  {"selector":"shadow_accuracy","text":"Shadow","type":"number"}]}]}
  ]
}