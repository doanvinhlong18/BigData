    {
      "id": 9,
      "title": "🌡️ All 263 Zones — Avg Demand (24h)",
      "description": "Màu ô = avg demand 24h qua. Sắp xếp theo avg demand giảm dần.",
      "type": "table",
      "gridPos": {
        "x": 0,
        "y": 33,
        "w": 24,
        "h": 12
      },
      "datasource": {
        "type": "postgres",
        "uid": "PostgreSQL"
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "PostgreSQL"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n    zone_id            AS \"Zone\",\n    ROUND(AVG(predicted_class)::numeric, 2) AS \"Avg Demand\",\n    MAX(predicted_class)                     AS \"Peak\",\n    MIN(predicted_class)                     AS \"Min\",\n    ROUND(AVG(pred_confidence)::numeric, 3)  AS \"Avg Conf\",\n    COUNT(*)                                 AS \"# Slots\",\n    MODE() WITHIN GROUP (ORDER BY used_model) AS \"Model\"\nFROM predictions_monitoring\nWHERE window_end >= (SELECT MAX(window_end) FROM predictions_monitoring) - INTERVAL '24 hours'\nGROUP BY zone_id\nORDER BY \"Avg Demand\" DESC, zone_id",
          "refId": "A"
        }
      ],
      "options": {
        "sortBy": [
          {
            "displayName": "Avg Demand",
            "desc": true
          }
        ],
        "footer": {
          "show": false
        },
        "frameIndex": 0
      },
